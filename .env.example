# Application
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8080
RUST_LOG=info,sqlx=warn,tower_http=info

# Postgres
POSTGRES_DB=codegraph
POSTGRES_USER=codegraph
POSTGRES_PASSWORD=codegraph
POSTGRES_PORT=5432
DATABASE_URL=postgres://codegraph:codegraph@localhost:5432/codegraph

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=code_chunks

# Providers: mock or openai_compatible
PROVIDER_MODE=mock
EMBEDDING_DIM=128
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Ingestion
MAX_FILE_BYTES=1048576
CHUNK_TARGET_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
REPOSITORY_WORKDIR=.codegraph/repos
